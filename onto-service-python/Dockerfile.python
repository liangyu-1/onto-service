FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application
COPY onto_service/ ./onto_service/

EXPOSE 5000

CMD ["python", "-m", "uvicorn", "onto_service.main:app", "--host", "0.0.0.0", "--port", "5000"]
